# Example environment variables for ML service
# Copy this file to .env and update the values

# Application
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

# API Gateway
API_GATEWAY_URL=http://localhost:3000

# ML Model Settings
MODEL_PATH=./models
EMBEDDING_DIMENSIONS=128
NODE2VEC_WALK_LENGTH=80
NODE2VEC_NUM_WALKS=10
NODE2VEC_WINDOW_SIZE=10
NODE2VEC_P=1
NODE2VEC_Q=1

# Data Paths
DATA_PATH=../data
RAW_DATA_PATH=../data/raw
PROCESSED_DATA_PATH=../data/processed
GRAPH_FILE=../data/email-Eu-core.txt
LABELS_FILE=../data/email-Eu-core-department-labels.txt

# Model Performance
MAX_WORKERS=4
BATCH_SIZE=32

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
